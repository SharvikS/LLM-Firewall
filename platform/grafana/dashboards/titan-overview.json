          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "titan-clickhouse" },
          "editorType": "sql",
          "format": 0,
          "queryType": "timeseries",
          "rawSql": "SELECT toStartOfHour(timestamp) AS time, count() AS requests, countIf(action != 'ALLOWED') AS blocked FROM titan.audit_events WHERE $__timeFilter(timestamp) GROUP BY time ORDER BY time",
          "refId": "A"
