          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT action, count() AS count, round(avg(risk_score), 3) AS avg_risk, max(timestamp) AS last_seen FROM titan.audit_events WHERE $__timeFilter(timestamp) AND action != 'ALLOWED' GROUP BY action ORDER BY count DESC LIMIT 10",
