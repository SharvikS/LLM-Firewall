          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT countIf(action != 'ALLOWED') / count() * 100 AS block_rate FROM titan.audit_events WHERE $__timeFilter(timestamp)",
          "refId": "A"
        }
