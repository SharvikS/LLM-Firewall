# TITAN Gateway — Environment Variables
# Copy this file to .env and fill in the values:  cp .env.example .env

# Admin token — protects /admin/v1/* endpoints and the dashboard admin API.
# Generate a strong secret: openssl rand -hex 32
ADMIN_TOKEN=your-admin-token-here

# ── ML governance gates (ml_engine) ──────────────────────────────────────────
# Toxicity / sentiment detection
TOXICITY_ENABLED=true
TOXICITY_BLOCK_THRESHOLD=0.85          # score (0-1) above which a prompt is BLOCKed

# Source-code / secret leak prevention
# Secrets are always masked; set this to BLOCK large source-code pastes instead
# of just flagging them.
CODE_LEAK_BLOCK=false
CODE_LEAK_MIN_LINES=8                  # min lines before the code-leak heuristic runs

# ── ClickHouse analytics (gateway) ───────────────────────────────────────────
# OLAP read path for the dashboard analytics endpoints (/api/analytics/*).
# Leave CLICKHOUSE_URL empty to disable (endpoints answer 503).
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=titan
