# Environment variables (NEVER COMMIT API KEYS)
.env
.env.*

# Go binaries and build artifacts
gateway/server
gateway/gateway
*.exe
*.exe~
*.dll
*.so
*.dylib

# Python bytecode
__pycache__/
*.pyc
*.pyo

# macOS Finder metadata
.DS_Store
**/.DS_Store

# TLS certs (generated by scripts/gen-certs.sh — never commit private keys)
certs/
*.key

# Python virtualenvs (never commit — multi-GB with torch)
venv/
**/venv/
.venv/
